diff --git a/src/middleware/rate-limit.ts b/src/middleware/rate-limit.ts
--- a/src/middleware/rate-limit.ts
+++ b/src/middleware/rate-limit.ts
@@ -1,0 +1,15 @@
+export function rateLimiter(options: RateLimitOptions) {
+  const hits = new Map<string, number[]>();
+  return (req: Request, res: Response, next: NextFunction) => {
+    const key = req.ip ?? 'unknown';
+    const now = Date.now();
+    const windowHits = (hits.get(key) ?? []).filter(t => now - t < options.windowMs);
+    if (windowHits.length >= options.max) {
+      return res.status(429).json({ error: 'Too many requests' });
+    }
+    windowHits.push(now);
+    hits.set(key, windowHits);
+    next();
+  };
+}
