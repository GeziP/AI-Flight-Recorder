{
  "name": "@gezip/aifr",
  "version": "0.1.1",
  "description": "AI Flight Recorder — OpenTelemetry for AI Software Development",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aifr": "bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin.js",
    "dist/index.cjs",
    "dist/index.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'no lint yet'"
  },
  "keywords": [
    "ai",
    "coding",
    "claude",
    "codex",
    "recorder",
    "replay",
    "observability",
    "developer-tools"
  ],
  "homepage": "https://github.com/GeziP/AI-Flight-Recorder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GeziP/AI-Flight-Recorder.git"
  },
  "bugs": {
    "url": "https://github.com/GeziP/AI-Flight-Recorder/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "@aifr/core": "workspace:^",
    "@aifr/event-schema": "workspace:^",
    "@aifr/parser-claude": "workspace:^",
    "@aifr/parser-codex": "workspace:^",
    "commander": "catalog:"
  },
  "optionalDependencies": {
    "node-pty": "catalog:"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  }
}
